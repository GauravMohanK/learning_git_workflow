import numpy as np
from collections import Counter


class KNN:

    def __init__(self, k=3):
        self.k = k

    def fit(self, X, y):
        self.X_train = X
        self.y_train = y

    def euclidean_distance(self, x1, x2):
        return np.sqrt(np.sum((x1 - x2) ** 2))

    def _predict(self, x):

        distances = [
            self.euclidean_distance(x, x_train)
            for x_train in self.X_train
        ]

        k_indices = np.argsort(distances)[:self.k]

        k_labels = self.y_train[k_indices]

        prediction = Counter(k_labels).most_common(1)[0][0]

        return prediction
    
    def _predict_proba(self, X):
        distance = np.linalg.norm(self.X_train - x, axis=1)

        k_indices = np.argpartition(distance, self.k)[:self.k]
        k_labels = self.y_train[k_indices]

        probabilities = []

        for cls in self.classes_:
            prob = np.sum(k_labels == cls) / self.k
            probabilities.append(prob)

        return np.array(probabilities)
     

    def predict(self, X):
        return np.array([self._predict(x) for x in X])
    
    
    def predict_proba(self, X):
        return np.array([self._predict_proba(x) for x in X])